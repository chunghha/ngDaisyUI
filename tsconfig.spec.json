{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "target": "es2016",
    "types": ["vitest/globals", "node"],
    "paths": {
      "@app": ["src/app/index.ts"],
      "@app/*": ["src/app/*"]
    }
  },
  "files": ["src/setupTest.ts"],
  "include": ["src/**/*.spec.ts", "src/**/*.d.ts"]
}
