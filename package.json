{
  "name": "ng-daisyui",
  "version": "0.3.2",
  "type": "module",
  "engines": {
    "node": ">=24.14.1 <25.0.0",
    "pnpm": ">=11.0.8 <12.0.0"
  },
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "pretest": "node scripts/check-no-test-filenames.mjs",
    "test": "vitest",
    "test:cov": "vitest run --coverage",
    "format": "pnpm dlx @biomejs/biome format --write ./src",
    "lint": "pnpm dlx @biomejs/biome lint ./src",
    "lint:fix": "pnpm dlx @biomejs/biome lint --write ./src",
    "check": "pnpm dlx @biomejs/biome check --write ./src",
    "check:unsafe": "pnpm dlx @biomejs/biome check --write --unsafe ./src",
    "check:all": "pnpm check && pnpm test:cov"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~21.2.15",
    "@angular/common": "~21.2.15",
    "@angular/compiler": "~21.2.15",
    "@angular/core": "~21.2.15",
    "@angular/forms": "~21.2.15",
    "@angular/platform-browser": "~21.2.15",
    "@angular/platform-browser-dynamic": "~21.2.15",
    "@angular/router": "~21.2.15",
    "@ngneat/elf": "~2.5.1",
    "@tanstack/angular-query-experimental": "^5.100.14",
    "@tanstack/query-core": "^5.100.14",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@analogjs/platform": "^2.5.2",
    "@analogjs/vite-plugin-angular": "^2.5.2",
    "@angular/build": "^21.2.13",
    "@angular/cli": "~21.2.13",
    "@angular/compiler-cli": "~21.2.15",
    "@biomejs/biome": "^2.4.16",
    "@fontsource/fira-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/angular": "^19.3.0",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.5.0",
    "daisyui": "~5.5.20",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.7"
  }
}
